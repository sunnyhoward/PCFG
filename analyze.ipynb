   "source": [
    "# ============================================================\n",
    "# Comprehensive Model Analysis\n",
    "#   1. Answer accuracy heatmaps  (distribution-matched evaluation)\n",
    "#   2. Per-layer gradient cosine similarity: count_a vs all other tasks\n",
    "#   3. Per-layer weight delta:  pretrain -> finetune -> forgot\n",
    "# ============================================================\n",
    "\n",
    "import random\n",
    "import torch\n",
    "import torch.nn.functional as F\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from pathlib import Path\n",
    "\n",
    "from mingpt import GPT, GPTConfig\n",
    "from pcfg_gen import (\n",
    "    CharTokenizer, PCFGGenerator, format_example,\n",
    "    PCFGDataset, collate_fn,\n",
    ")\n",
    "from config import CFG\n",
    "from config_utils import build_task_registry\n",
    "\n",
    "# -----------------------------------------------------------\n",
    "# Shared Setup\n",
    "# -----------------------------------------------------------\n",
    "device        = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
    "print(f'Using device: {device}')\n",
    "\n",
    "tokenizer     = CharTokenizer()\n",
    "task_registry = build_task_registry(CFG['task_definitions'])\n",
    "pcfg_gen      = PCFGGenerator()\n",
    "\n",
    "_mcfg = CFG['model']\n",
    "gpt_config = GPTConfig(\n",
    "    vocab_size  = tokenizer.vocab_size,\n",
    "    block_size  = _mcfg['block_size'],\n",
    "    n_layer     = _mcfg['n_layer'],\n",
    "    n_head      = _mcfg['n_head'],\n",
    "    n_embd      = _mcfg['n_embd'],\n",
    "    embd_pdrop  = 0.0,\n",
    "    resid_pdrop = 0.0,\n",
    "    attn_pdrop  = 0.0,\n",
    ")\n",
    "\n",
    "MODEL_DIR  = Path('results/models')\n",
    "CHUNK_SIZE = CFG['pcfg']['chunk_size']   # 250\n",
    "\n",
    "CORRS = [0.00, 0.25, 0.50, 0.75, 1.00]\n",
    "CONCS = [0.10, 0.30, 0.50, 0.70, 0.90]\n",
    "\n",
    "ALL_TASKS   = CFG['task_sets']['finetune']\n",
    "COUNT_A     = 'count_a'\n",
    "COUNT_B     = 'count_b'\n",
    "OTHER_TASKS = [t for t in ALL_TASKS if t not in (COUNT_A, COUNT_B)]\n",
    "\n",
    "# -- Tunable ---------------------------------------------------\n",
    "N_EVAL = 30    # eval strings per task per model  (accuracy heatmaps)\n",
    "N_GRAD = 15    # gradient-averaging samples per task group\n",
    "# --------------------------------------------------------------\n",
    "\n",
    "N_LAYERS    = _mcfg['n_layer']\n",
    "LAYER_ORDER = (\n",
    "    ['embeddings']\n",
    "    + [f'block_{i:02d}' for i in range(N_LAYERS)]\n",
    "    + ['ln_f', 'lm_head']\n",
    ")\n",
    "\n",
    "# -----------------------------------------------------------\n",
    "# Utilities\n",
    "# -----------------------------------------------------------\n",
    "\n",
    "def gen_mixed_strings(n: int, corr: float) -> list:\n",
    "    \"\"\"n PCFG strings where `corr` fraction satisfy count_a == count_b + 1.\"\"\"\n",
    "    n_c = round(n * corr)\n",
    "    out = [pcfg_gen.generate_correlated_chunk(CHUNK_SIZE) for _ in range(n_c)]\n",
    "    out += [pcfg_gen.generate_chunk(CHUNK_SIZE) for _ in range(n - n_c)]\n",
    "    random.shuffle(out)\n",
    "    return out\n",
    "\n",
    "\n",
    "def load_model(path: Path) -> GPT:\n",
    "    model = GPT(gpt_config)\n",
    "    ckpt  = torch.load(path, map_location='cpu')\n",
    "    model.load_state_dict(ckpt.get('model_state_dict', ckpt))\n",
    "    return model.to(device)\n",
    "\n",
    "\n",
    "def _lkey(name: str) -> str:\n",
    "    \"\"\"Parameter name -> layer-group key.\"\"\"\n",
    "    parts = name.split('.')\n",
    "    if 'transformer' in parts and 'h' in parts:\n",
    "        idx = parts.index('h')\n",
    "        return f'block_{int(parts[idx + 1]):02d}'\n",
    "    if 'wte' in name or 'wpe' in name:\n",
    "        return 'embeddings'\n",
    "    if 'ln_f' in name:\n",
    "        return 'ln_f'\n",
    "    if 'lm_head' in name:\n",
    "        return 'lm_head'\n",
    "    return 'other'\n",
    "\n",
    "\n",
    "@torch.no_grad()\n",
    "def eval_acc(model, task_name: str, strings: list) -> float:\n",
    "    \"\"\"Answer accuracy of model on task_name given pre-generated strings.\"\"\"\n",
    "    model.eval()\n",
    "    correct = 0\n",
    "    for s in strings:\n",
    "        td, ans   = task_registry.apply_task(task_name, s)\n",
    "        ex        = format_example(s, td, ans)\n",
    "        ds        = PCFGDataset([ex], tokenizer, max_length=512, mask_answer_only=True)\n",
    "        b         = collate_fn([ds[0]], tokenizer)\n",
    "        logits, _ = model(b['input_ids'].to(device), b['target_ids'].to(device))\n",
    "        pos = b['answer_positions'][0]\n",
    "        if not pos:\n",
    "            continue\n",
    "        ok  = all(logits[0, p].argmax().item() == b['target_ids'][0, p].item()\n",
    "                  for p in pos)\n",
    "        correct += int(ok)\n",
    "    return correct / max(len(strings), 1)\n",
    "\n",
    "\n",
    "def avg_grads(model, task_names: list, strings: list) -> dict:\n",
    "    \"\"\"Average per-layer flattened gradient vectors over given strings.\"\"\"\n",
    "    model.train()\n",
    "    acc, cnt = {}, {}\n",
    "    for s in strings:\n",
    "        tn      = random.choice(task_names)\n",
    "        td, ans = task_registry.apply_task(tn, s)\n",
    "        ex      = format_example(s, td, ans)\n",
    "        ds      = PCFGDataset([ex], tokenizer, max_length=512, mask_answer_only=True)\n",
    "        b       = collate_fn([ds[0]], tokenizer)\n",
    "        model.zero_grad()\n",
    "        _, loss = model(b['input_ids'].to(device), b['target_ids'].to(device))\n",
    "        loss.backward()\n",
    "        for nm, param in model.named_parameters():\n",
    "            if param.grad is None:\n",
    "                continue\n",
    "            k = _lkey(nm)\n",
    "            g = param.grad.detach().cpu().float().flatten()\n",
    "            if k in acc:\n",
    "                acc[k] += g\n",
    "                cnt[k] += 1\n",
    "            else:\n",
    "                acc[k] = g.clone()\n",
    "                cnt[k] = 1\n",
    "    model.zero_grad()\n",
    "    return {k: acc[k] / cnt[k] for k in acc}\n",
    "\n",
    "\n",
    "def weight_delta_norms(base: GPT, other: GPT) -> dict:\n",
    "    \"\"\"Per-layer L2 norm of (other - base) weight delta.\"\"\"\n",
    "    buf = {}\n",
    "    for (na, pa), (_, pb) in zip(base.named_parameters(), other.named_parameters()):\n",
    "        k = _lkey(na)\n",
    "        d = (pb.detach().cpu().float() - pa.detach().cpu().float()).flatten()\n",
    "        buf.setdefault(k, []).append(d)\n",
    "    return {k: torch.cat(v).norm().item() for k, v in buf.items()}\n",
    "\n",
    "\n",
    "def _plot_heatmap(ax, mat, row_lbl, col_lbl, title,\n",
    "                  vmin=None, vmax=None, cmap='viridis', fmt='.2f'):\n",
    "    lo = vmin if vmin is not None else (float(np.nanmin(mat)) if not np.all(np.isnan(mat)) else 0.0)\n",
    "    hi = vmax if vmax is not None else (float(np.nanmax(mat)) if not np.all(np.isnan(mat)) else 1.0)\n",
    "    im = ax.imshow(mat, aspect='auto', interpolation='nearest',\n",
    "                   vmin=lo, vmax=hi, cmap=cmap)\n",
    "    ax.set_title(title, fontsize=10)\n",
    "    ax.set_xlabel('Concentration')\n",
    "    ax.set_ylabel('Correlation')\n",
    "    ax.set_xticks(range(len(col_lbl)))\n",
    "    ax.set_xticklabels([f'{c}' for c in col_lbl], rotation=45, ha='right')\n",
    "    ax.set_yticks(range(len(row_lbl)))\n",
    "    ax.set_yticklabels([f'{r}' for r in row_lbl])\n",
    "    for i in range(mat.shape[0]):\n",
    "        for j in range(mat.shape[1]):\n",
    "            v = mat[i, j]\n",
    "            if np.isnan(v):\n",
    "                continue\n",
    "            frac = (v - lo) / max(hi - lo, 1e-9)\n",
    "            tc   = 'white' if frac < 0.5 else 'black'\n",
    "            ax.text(j, i, format(v, fmt), ha='center', va='center', fontsize=8, color=tc)\n",
    "    return im\n",
    "\n",
    "\n",
    "def _build_model_layer_matrix(stage_dict):\n",
    "    \"\"\"Build (n_models x n_layers) matrix; rows are (corr,conc) combos, cols are layers.\"\"\"\n",
    "    keys = sorted(stage_dict.keys())\n",
    "    mat  = np.full((len(keys), len(LAYER_ORDER)), np.nan)\n",
    "    lbls = []\n",
    "    for row, (ci, cj) in enumerate(keys):\n",
    "        lbls.append(f'r{CORRS[ci]:.2f}_c{CONCS[cj]:.2f}')\n",
    "        d = stage_dict[(ci, cj)]\n",
    "        for col, lk in enumerate(LAYER_ORDER):\n",
    "            if lk in d:\n",
    "                mat[row, col] = d[lk]\n",
    "    return mat, lbls\n",
    "\n",
    "\n",
    "colors_corr = plt.cm.plasma(np.linspace(0, 0.9, len(CORRS)))\n",
    "\n",
    "\n",
    "# ==============================================================\n",
    "# SECTION 1 - Answer Accuracy Heatmaps (distribution-matched)\n",
    "# ==============================================================\n",
    "print('\\n' + '='*60)\n",
    "print('SECTION 1  -- Answer Accuracy Heatmaps')\n",
    "print('='*60)\n",
    "\n",
    "stages      = ['finetune', 'reverse']\n",
    "task_groups = ['count_a', 'count_b', 'other_avg']\n",
    "\n",
    "acc = {st: {tg: np.full((len(CORRS), len(CONCS)), np.nan)\n",
    "            for tg in task_groups}\n",
    "       for st in stages}\n",
    "\n",
    "for ci, corr in enumerate(CORRS):\n",
    "    # Generate evaluation strings that match this correlation level\n",
    "    strings = gen_mixed_strings(N_EVAL, corr)\n",
    "    print(f'\\n  corr={corr:.2f}  |  generated {len(strings)} eval strings '\n",
    "          f'({round(N_EVAL * corr)} correlated, {N_EVAL - round(N_EVAL * corr)} uncorrelated)')\n",
    "    for cj, conc in enumerate(CONCS):\n",
    "        for stage in stages:\n",
    "            mpath = MODEL_DIR / f'{stage}_corr_{corr:.2f}_conc_{conc:.2f}.pth'\n",
    "            if not mpath.exists():\n",
    "                continue\n",
    "            model = load_model(mpath)\n",
    "            a_a   = eval_acc(model, COUNT_A, strings)\n",
    "            a_b   = eval_acc(model, COUNT_B, strings)\n",
    "            a_o   = float(np.mean([eval_acc(model, t, strings) for t in OTHER_TASKS]))\n",
    "            acc[stage]['count_a'][ci, cj]   = a_a\n",
    "            acc[stage]['count_b'][ci, cj]   = a_b\n",
    "            acc[stage]['other_avg'][ci, cj] = a_o\n",
    "            del model\n",
    "            if device.type == 'cuda':\n",
    "                torch.cuda.empty_cache()\n",
    "            print(f'    {stage:<10} conc={conc:.2f}  | '\n",
    "                  f'count_a={a_a:.3f}  count_b={a_b:.3f}  other={a_o:.3f}')\n",
    "\n",
