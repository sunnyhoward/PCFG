   "source": [
    "# ============================================================\n",
    "# Gradient Analysis: count(a) prompts vs other task prompts\n",
    "# Cosine similarity of gradient vectors per transformer layer\n",
    "# ============================================================\n",
    "\n",
    "import random\n",
    "import torch\n",
    "import torch.nn.functional as F\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from pathlib import Path\n",
    "\n",
    "from mingpt import GPT, GPTConfig\n",
    "from pcfg_gen import (\n",
    "    CharTokenizer, PCFGGenerator, format_example,\n",
    "    PCFGDataset, collate_fn,\n",
    ")\n",
    "from config import CFG\n",
    "from config_utils import build_task_registry\n",
    "\n",
    "# ---- Setup ----\n",
    "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
    "print(f'Using device: {device}')\n",
    "\n",
    "tokenizer = CharTokenizer()\n",
    "\n",
    "model_cfg = CFG['model']\n",
    "gpt_config = GPTConfig(\n",
    "    vocab_size=tokenizer.vocab_size,\n",
    "    block_size=model_cfg['block_size'],\n",
    "    n_layer=model_cfg['n_layer'],\n",
    "    n_head=model_cfg['n_head'],\n",
    "    n_embd=model_cfg['n_embd'],\n",
    "    embd_pdrop=0.0,   # disable dropout for cleaner gradients\n",
    "    resid_pdrop=0.0,\n",
    "    attn_pdrop=0.0,\n",
    ")\n",
    "\n",
    "task_registry = build_task_registry(CFG['task_definitions'])\n",
    "pcfg_gen      = PCFGGenerator()\n",
    "\n",
    "MODEL_DIR  = Path('results/models')\n",
    "CHUNK_SIZE = 250\n",
    "N_SAMPLES  = 30   # per task group, per model\n",
    "\n",
    "# Models to analyse: (stage, corr, conc)\n",
    "MODEL_SPECS = [\n",
    "    ('finetune', 0.50, 0.10),\n",
    "    ('finetune', 0.50, 0.30),\n",
    "    ('finetune', 0.50, 0.50),\n",
    "    ('finetune', 0.50, 0.70),\n",
    "    ('finetune', 0.50, 0.90),\n",
    "    # ('finetune', 0.50, 0.90),\n",
    "    # ('finetune', 1.00, 0.90),\n",
    "]\n",
    "\n",
    "# Task groups\n",
    "COUNT_A_TASKS = ['count_a']\n",
    "OTHER_TASKS   = ['count_c', 'count_aa', 'index_a', 'token_at_40']\n",
    "\n",
    "\n",
    "# ---- Gradient helpers ----\n",
    "\n",
    "def _layer_key(param_name: str) -> str:\n",
    "    \"\"\"Map a parameter name to a readable layer-group key.\"\"\"\n",
    "    parts = param_name.split('.')\n",
    "    if 'transformer' in parts and 'h' in parts:\n",
    "        h_idx = parts.index('h')\n",
    "        return f'block_{int(parts[h_idx + 1]):02d}'\n",
    "    if 'wte' in param_name or 'wpe' in param_name:\n",
    "        return 'embeddings'\n",
    "    if 'ln_f' in param_name:\n",
    "        return 'ln_f'\n",
    "    if 'lm_head' in param_name:\n",
    "        return 'lm_head'\n",
    "    return 'other'\n",
    "\n",
    "\n",
    "def sample_grad_vectors(model, pcfg_string: str, task_name: str, device):\n",
    "    \"\"\"Compute per-layer flattened gradient vectors for one (string, task) sample.\"\"\"\n",
    "    task_def, answer = task_registry.apply_task(task_name, pcfg_string)\n",
    "    example = format_example(pcfg_string, task_def, answer)\n",
    "\n",
    "    dataset = PCFGDataset([example], tokenizer, max_length=512, mask_answer_only=True)\n",
    "    batch   = collate_fn([dataset[0]], tokenizer)\n",
    "\n",
    "    model.zero_grad()\n",
    "    _, loss = model(batch['input_ids'].to(device), batch['target_ids'].to(device))\n",
    "    loss.backward()\n",
    "\n",
    "    parts = {}\n",
    "    for name, param in model.named_parameters():\n",
    "        if param.grad is None:\n",
    "            continue\n",
    "        key = _layer_key(name)\n",
    "        parts.setdefault(key, []).append(\n",
    "            param.grad.detach().cpu().float().flatten()\n",
    "        )\n",
    "\n",
    "    model.zero_grad()\n",
    "    return {k: torch.cat(v) for k, v in parts.items()}\n",
    "\n",
    "\n",
    "def avg_grad_vectors(model, task_names, n_samples, device):\n",
    "    \"\"\"Average per-layer gradient vectors over n_samples drawn from task_names.\"\"\"\n",
    "    accumulated, counts = {}, {}\n",
    "    for _ in range(n_samples):\n",
    "        pcfg_string = pcfg_gen.generate_chunk(CHUNK_SIZE)\n",
    "        task_name   = random.choice(task_names)\n",
    "        grads = sample_grad_vectors(model, pcfg_string, task_name, device)\n",
    "        for k, v in grads.items():\n",
    "            if k not in accumulated:\n",
    "                accumulated[k] = v.clone()\n",
    "                counts[k] = 1\n",
    "            else:\n",
    "                accumulated[k] += v\n",
    "                counts[k] += 1\n",
    "    return {k: accumulated[k] / counts[k] for k in accumulated}\n",
    "\n",
    "\n",
    "def cossim(a: torch.Tensor, b: torch.Tensor) -> float:\n",
    "    return F.cosine_similarity(a.unsqueeze(0), b.unsqueeze(0)).item()\n",
    "\n",
    "\n",
    "# ---- Main analysis loop ----\n",
    "\n",
    "results_grad = {}   # run_key -> {layer_key: cosine_sim}\n",
    "\n",
    "for (stage, corr, conc) in MODEL_SPECS:\n",
    "    model_path = MODEL_DIR / f'{stage}_corr_{corr:.2f}_conc_{conc:.2f}.pth'\n",
    "    print(f\"\\n{'─'*60}\")\n",
    "    print(f'Loading  {model_path.name}')\n",
    "\n",
    "    model = GPT(gpt_config)\n",
    "    ckpt  = torch.load(model_path, map_location='cpu')\n",
    "    model.load_state_dict(ckpt['model_state_dict'])\n",
    "    model.to(device)\n",
    "    model.train()   # train mode so grads are well-defined\n",
    "\n",
    "    print(f'  → count_a gradients   ({N_SAMPLES} samples) …')\n",
    "    grads_count_a = avg_grad_vectors(model, COUNT_A_TASKS, N_SAMPLES, device)\n",
    "\n",
    "    print(f'  → other task gradients ({N_SAMPLES} samples) …')\n",
    "    grads_other   = avg_grad_vectors(model, OTHER_TASKS,   N_SAMPLES, device)\n",
    "\n",
    "    common = sorted(set(grads_count_a) & set(grads_other))\n",
    "    sims   = {layer: cossim(grads_count_a[layer], grads_other[layer])\n",
    "              for layer in common}\n",
    "\n",
    "    run_key = f'{stage} | corr={corr:.2f} | conc={conc:.2f}'\n",
    "    results_grad[run_key] = sims\n",
    "\n",
    "    print('  Layer cosine similarities (count_a vs other):')\n",
    "    for layer in common:\n",
    "        print(f'    {layer:15s}: {sims[layer]:+.4f}')\n",
    "\n",
    "\n",
    "# ---- Plot ----\n",
    "\n",
    "layer_order = sorted(results_grad[next(iter(results_grad))].keys())\n",
    "x = np.arange(len(layer_order))\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(11, 5))\n",
    "for run_key, sims in results_grad.items():\n",
    "    vals = [sims.get(l, np.nan) for l in layer_order]\n",
    "    ax.plot(x, vals, marker='o', label=run_key)\n",
    "\n",
    "ax.axhline(0, color='gray', linewidth=0.8, linestyle='--')\n",
    "ax.set_xticks(x)\n",
    "ax.set_xticklabels(layer_order, rotation=45, ha='right')\n",
    "ax.set_xlabel('Layer group')\n",
    "ax.set_ylabel('Cosine Similarity')\n",
    "ax.set_title('Gradient cosine similarity: count(a) vs other tasks — per layer')\n",
    "ax.legend(loc='upper left', bbox_to_anchor=(1.01, 1.0), fontsize=9)\n",
    "ax.grid(alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.show()\n"
   ]
  },
